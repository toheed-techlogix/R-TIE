# Copy this file to .env.dev (local) or .env.prod and fill in real values.
# Do NOT commit files containing real secrets.

# --- Oracle (OFSAA source) ---
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SID=orclpdb
ORACLE_USER=your_oracle_user
ORACLE_PASSWORD=your_oracle_password

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rtie
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password

# --- LLM providers ---
# OpenAI (api.openai.com)
OPENAI_API_KEY=sk-your-openai-key

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Default model provider: "openai" or "anthropic"
DEFAULT_LLM_PROVIDER=openai
# Default model name per provider
OPENAI_MODEL=gpt-5-mini
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Embedding model for semantic search
EMBEDDING_MODEL=text-embedding-3-small

# --- LangSmith tracing (optional) ---
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_your_langsmith_key
LANGSMITH_PROJECT=RTIE

# --- Runtime ---
ENVIRONMENT=dev
